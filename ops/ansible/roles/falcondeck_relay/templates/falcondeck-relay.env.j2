FALCONDECK_RELAY_BIND={{ falcondeck_relay_bind_host }}:{{ falcondeck_relay_port }}
{% if falcondeck_relay_database_url | trim %}
FALCONDECK_RELAY_DATABASE_URL={{ falcondeck_relay_database_url }}
{% elif falcondeck_relay_postgres_enabled %}
FALCONDECK_RELAY_DATABASE_URL=postgresql://{{ falcondeck_relay_postgres_user }}:{{ falcondeck_relay_postgres_password }}@{{ falcondeck_relay_postgres_host }}:{{ falcondeck_relay_postgres_port }}/{{ falcondeck_relay_postgres_db }}
{% else %}
FALCONDECK_RELAY_STATE_PATH={{ falcondeck_relay_data_dir }}/state.json
{% endif %}
{% for key, value in falcondeck_relay_env.items() %}
{{ key }}={{ value }}
{% endfor %}
