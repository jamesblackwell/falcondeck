{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FalconDeck",
  "version": "0.1.0",
  "identifier": "com.falcondeck.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FalconDeck",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 1520,
        "height": 980,
        "minWidth": 1120,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "__FALCONDECK_UPDATER_PUBLIC_KEY__",
      "endpoints": [
        "https://github.com/jamesblackwell/falcondeck/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
